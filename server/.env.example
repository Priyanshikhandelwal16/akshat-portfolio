PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Replace with your actual MongoDB Atlas connection string.
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio_cms?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio_cms?retryWrites=true&w=majority

# ── Security ────────────────────────────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production.
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_64_CHARS_MIN

# Optional: Initial admin password for database seeding (defaults to "admin123" if omitted)
ADMIN_PASSWORD=your_secure_admin_password_here

# ── CORS ────────────────────────────────────────────────────────────────────────
# Set this to your production frontend domain (no trailing slash).
# Example: https://akshatjain.com or https://your-app.onrender.com
CORS_ORIGIN=https://your-production-domain.com

# ── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Resend Email ───────────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
# IMPORTANT: Also verify your sending domain at https://resend.com/domains
# Until a custom domain is verified, you MUST send from: onboarding@resend.dev
# and can only deliver to your own verified email address.
RESEND_API_KEY=your_resend_api_key_here

# ── Resend Email Delivery ──────────────────────────────────────────────────────
# The "from" address Resend will use to send contact form emails.
# Options:
#   a) onboarding@resend.dev       → Resend sandbox (works without domain, delivers only to verified addresses)
#   b) noreply@yourdomain.com      → Custom domain (requires domain verification in Resend dashboard)
RESEND_FROM_EMAIL=onboarding@resend.dev

# The email address that receives contact form submissions.
RESEND_TO_EMAIL=creatorakshat7@gmail.com
